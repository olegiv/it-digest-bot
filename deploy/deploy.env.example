# Copy this file to deploy/deploy.env and edit. Sourced by every script
# in deploy/ (via lib.sh); gitignored so it stays personal.

# Required: SSH target. Either a bare hostname (defaults to root@<host>)
# or an explicit user@host.
DEPLOY_HOST=server.example.com

# Optional: override the default daily-backup retention (14 days).
#IT_DIGEST_BACKUP_KEEP_DAYS=30
