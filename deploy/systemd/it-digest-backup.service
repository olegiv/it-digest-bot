[Unit]
Description=it-digest-bot — daily SQLite state backup

# Post a Telegram alert on nonzero exit (see it-digest-notify@.service).
OnFailure=it-digest-notify@%N.service

[Service]
Type=oneshot
User=it-digest
Group=it-digest
ExecStart=/usr/local/bin/it-digest-backup
StandardOutput=journal
StandardError=journal

# Hardening — no network needed. The DB dir is writable because WAL
# mode requires mmap'ing the -shm sidecar even on read-only opens;
# the script still uses `sqlite3 -readonly` so the source is untouched.
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
ReadWritePaths=/var/lib/it-digest
ReadWritePaths=/var/backups/it-digest
RestrictSUIDSGID=true
LockPersonality=true
MemoryDenyWriteExecute=true
SystemCallArchitectures=native
RestrictAddressFamilies=AF_UNIX
SystemCallFilter=@system-service
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictNamespaces=true
