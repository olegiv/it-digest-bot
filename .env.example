# Copy to .env (or /etc/it-digest/env in production) and fill in.
# Never commit the real file — .env is gitignored.

# Required for `digest watch` and `digest daily` (anything that posts).
TELEGRAM_BOT_TOKEN=

# Required for `digest daily` (phase 2). Not needed for `digest watch`.
ANTHROPIC_API_KEY=

# Optional. A personal access token raises GitHub's rate limit from 60
# req/hour (unauthenticated) to 5000 req/hour. Only needs `public_repo`
# scope for the anthropics/claude-code release-notes fetch.
GITHUB_TOKEN=
